{
  "name": "@ce-net/cap",
  "version": "0.1.0",
  "description": "Pure-TS, runtime-agnostic CE capability library — bincode-1 encoding, Ed25519 signing, and attenuating capability-chain verification, byte-exact with the Rust ce-cap crate.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Leif Rydenfalk <ledamecrydenfalk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ce-net/ce-ts.git",
    "directory": "cap"
  },
  "homepage": "https://ce-net.com",
  "keywords": [
    "ce",
    "ce-net",
    "capability",
    "ed25519",
    "bincode",
    "authorization",
    "ucan"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
