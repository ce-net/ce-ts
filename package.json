{
  "name": "@ce-net/sdk",
  "version": "0.1.0",
  "description": "Runtime-agnostic TypeScript client for the CE node HTTP+SSE API.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openapi.yaml"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Leif Rydenfalk <ledamecrydenfalk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ce-net/ce-ts.git"
  },
  "homepage": "https://ce-net.com",
  "keywords": [
    "ce",
    "ce-net",
    "compute",
    "blockchain",
    "sdk",
    "client"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsdown && publint && attw --pack"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@types/node": "^22.0.0",
    "publint": "^0.3.0",
    "tsdown": "^0.12.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
